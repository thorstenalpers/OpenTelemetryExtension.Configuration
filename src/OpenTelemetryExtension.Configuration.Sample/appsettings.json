{
  "Telemetry": {
    "Enabled": true,
    "ServiceName": "api",
    "EnvironmentName": "Test",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogging": true,
    "EnableAspNetCoreInstrumentation": true,
    "EnableHttpClientInstrumentation": true,
    "EnableSqlClientInstrumentation": true,
    "EnableRuntimeInstrumentation": true,
    "RecordExceptions": true,
    "ExcludeHealthChecks": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,31433;Database=TelemetryDb;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=True"
  },
  "AllowedHosts": "*"
}