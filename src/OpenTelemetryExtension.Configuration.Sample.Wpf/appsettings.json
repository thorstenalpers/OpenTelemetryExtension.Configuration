{
  "Telemetry": {
    "Endpoint": "http://localhost:4318",
    "Protocol": "HttpProtobuf",
    "ServiceName": "sample-wpf",
    "ResourceAttributes": {
      "deployment.environment": "Development"
    },
    "EnableAspNetCoreInstrumentation": false,
    "AdditionalTracingSources": [ "Sample.Wpf" ],
    "AdditionalMeters": [ "Sample.Wpf" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
