<Window x:Class="OpenTelemetryExtension.Configuration.Sample.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenTelemetry WPF Sample" Height="280" Width="500"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock Text="OpenTelemetryExtension.Configuration — WPF sample"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,16"
                   Text="Click the button to emit a traced span, increment a counter metric and write a log record — all exported over OTLP." />
        <Button x:Name="WorkButton" Content="Do traced work" Padding="12,6"
                HorizontalAlignment="Left" Click="OnDoWorkClick" />
        <TextBlock x:Name="StatusText" Margin="0,16,0,0" Foreground="Gray" TextWrapping="Wrap" />
    </StackPanel>
</Window>
